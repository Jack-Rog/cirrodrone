# -------------------------------------------------------------------
# Cirro environment variables
# Copy this file to `.env.local` for local development.
# Only variables prefixed with `NEXT_PUBLIC_` are exposed to the browser.
# -------------------------------------------------------------------

# -------------------------------------------------------------------
# Required public Supabase config
# Safe for browser usage.
# -------------------------------------------------------------------

# Supabase project URL from Settings -> API / Connect.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Current browser-safe Supabase key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# -------------------------------------------------------------------
# Required server-only Supabase config
# Never expose these in client code.
# -------------------------------------------------------------------

# Current server-side Supabase key.
SUPABASE_SECRET_KEY=your-secret-key

# Private token used to unlock the in-app beta inbox at /admin/beta-access.
BETA_ACCESS_ADMIN_TOKEN=choose-a-long-random-string

# -------------------------------------------------------------------
# Optional compatibility fallbacks
# These are supported by the repo during transition from older setups.
# Prefer the keys above for all new environments.
# -------------------------------------------------------------------

# Optional legacy browser-safe fallback.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-side URL override.
SUPABASE_URL=

# Optional legacy server-side fallback.
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------------------------------
# Optional integrations / local fallback behavior
# -------------------------------------------------------------------

# If Supabase is not configured, beta access can post to a webhook instead.
EARLY_ACCESS_WEBHOOK_URL=
