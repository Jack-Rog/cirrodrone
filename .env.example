# Supabase beta-access persistence
# Use the Project URL from Supabase Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Server-side only. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional fallback when Supabase is not configured.
EARLY_ACCESS_WEBHOOK_URL=
